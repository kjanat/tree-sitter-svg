{
	"name": "tree-sitter-svg",
	"version": "0.1.0",
	"description": "SVG grammar for Tree-sitter",
	"keywords": [
		"incremental",
		"parsing",
		"tree-sitter",
		"svg"
	],
	"homepage": "https://github.com/kjanat/tree-sitter-svg#readme",
	"bugs": {
		"url": "https://github.com/kjanat/tree-sitter-svg/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/tree-sitter-svg.git"
	},
	"funding": {
		"url": "https://github.com/kjanat/funding"
	},
	"license": "MIT",
	"author": "Kaj Kowalski <info@kajkowalski.nl> (https://github.com/kjanat)",
	"type": "module",
	"main": "bindings/node",
	"types": "bindings/node",
	"directories": {
		"test": "test"
	},
	"files": [
		"grammar.js",
		"tree-sitter.json",
		"binding.gyp",
		"prebuilds/**",
		"bindings/node/*",
		"queries/*",
		"src/**",
		"*.wasm"
	],
	"scripts": {
		"fmt": "dprint fmt",
		"helix:sync": "DIR=\"${HOME}/.config/helix/runtime/queries/svg\"; mkdir -p \"${DIR}\" && cp queries/*.scm \"${DIR}\"",
		"install": "node-gyp-build",
		"postinstall": "git config core.hooksPath .githooks",
		"prestart": "tree-sitter build --wasm",
		"start": "tree-sitter playground --quiet",
		"test": "node --test bindings/node/*_test.js",
		"test:corpus": "tree-sitter test",
		"test:fuzz": "tree-sitter fuzz --iterations 50 --edits 5",
		"test:fuzz:quick": "tree-sitter fuzz --iterations 10 --edits 3",
		"test:parse-samples": "for f in samples/*.svg samples/assets/*.svg samples/w3/*.svg; do tree-sitter parse \"$f\" 2>&1 | grep -q ERROR && echo \"FAIL: $f\" && exit 1; done; echo 'All samples OK'",
		"test:regex": "CI=1 bun test test/regex_samples/regex_harness.test.ts",
		"test:regex:dev": "bun test test/regex_samples/regex_harness.test.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"node-addon-api": "^8.5.0",
		"node-gyp-build": "^4.8.4"
	},
	"devDependencies": {
		"@types/bun": "^1.3.11",
		"prebuildify": "^6.0.1",
		"tree-sitter": "^0.25.0",
		"tree-sitter-cli": "^0.26.7",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"tree-sitter": "^0.25.0"
	},
	"peerDependenciesMeta": {
		"tree-sitter": {
			"optional": true
		}
	},
	"packageManager": "bun@1.3.11",
	"volta": {
		"node": "22.22.1"
	}
}
