{
	"name": "tree-sitter-svg",
	"version": "0.1.0",
	"description": "SVG grammar for Tree-sitter",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/tree-sitter-svg.git"
	},
	"funding": "https://github.com/kjanat/funding",
	"license": "MIT",
	"author": {
		"name": "Kaj Kowalski",
		"email": "info@kajkowalski.nl",
		"url": "https://github.com/kjanat"
	},
	"main": "bindings/node",
	"types": "bindings/node",
	"keywords": [
		"incremental",
		"parsing",
		"tree-sitter",
		"svg"
	],
	"files": [
		"grammar.js",
		"tree-sitter.json",
		"binding.gyp",
		"prebuilds/**",
		"bindings/node/*",
		"queries/*",
		"src/**",
		"*.wasm"
	],
	"dependencies": {
		"node-addon-api": "^8.5.0",
		"node-gyp-build": "^4.8.4"
	},
	"devDependencies": {
		"prebuildify": "^6.0.1",
		"tree-sitter": "^0.25.0",
		"tree-sitter-cli": "^0.26.7"
	},
	"peerDependencies": {
		"tree-sitter": "^0.25.0"
	},
	"peerDependenciesMeta": {
		"tree-sitter": {
			"optional": true
		}
	},
	"scripts": {
		"install": "node-gyp-build",
		"postinstall": "git config core.hooksPath .githooks",
		"prestart": "tree-sitter build --wasm",
		"start": "tree-sitter playground",
		"test": "node --test bindings/node/*_test.js"
	},
	"packageManager": "bun@1.3.11"
}
