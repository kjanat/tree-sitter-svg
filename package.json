{
	"name": "tree-sitter-svg",
	"version": "0.1.0",
	"description": "SVG grammar for Tree-sitter",
	"keywords": [
		"incremental",
		"parsing",
		"tree-sitter",
		"svg"
	],
	"homepage": "https://github.com/kjanat/tree-sitter-svg#readme",
	"bugs": {
		"url": "https://github.com/kjanat/tree-sitter-svg/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjanat/tree-sitter-svg.git"
	},
	"funding": {
		"url": "https://github.com/kjanat/funding"
	},
	"license": "MIT",
	"author": "Kaj Kowalski <info@kajkowalski.nl> (https://github.com/kjanat)",
	"type": "module",
	"main": "bindings/node",
	"types": "bindings/node",
	"directories": {
		"test": "test"
	},
	"files": [
		"grammar.js",
		"tree-sitter.json",
		"binding.gyp",
		"prebuilds/**",
		"bindings/node/*",
		"queries/*",
		"src/**",
		"*.wasm"
	],
	"scripts": {
		"fmt": "dprint fmt .",
		"helix:sync": "DIR=\"${HOME}/.config/helix/runtime/queries/svg\"; mkdir -p \"${DIR}\" && cp queries/*.scm \"${DIR}\"",
		"install": "node-gyp-build",
		"postinstall": "git config core.hooksPath .githooks",
		"prestart": "tree-sitter build --wasm",
		"start": "tree-sitter playground --quiet",
		"test": "node --test bindings/node/*_test.js"
	},
	"dependencies": {
		"node-addon-api": "^8.5.0",
		"node-gyp-build": "^4.8.4"
	},
	"devDependencies": {
		"prebuildify": "^6.0.1",
		"tree-sitter": "^0.25.0",
		"tree-sitter-cli": "^0.26.7"
	},
	"peerDependencies": {
		"tree-sitter": "^0.25.0"
	},
	"peerDependenciesMeta": {
		"tree-sitter": {
			"optional": true
		}
	},
	"packageManager": "bun@1.3.11",
	"volta": {
		"node": "22.22.1"
	}
}
